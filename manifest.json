{
  "name": "Reels Party",
  "description": "Synchronise les vidéos que tu regardes avec tes amis en temps réel !",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_icon": "reels_party_icon.png"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["socket.io.min.js", "background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "reelsparty@frohub.eu",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.tiktok.com/*",
    "*://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.tiktok.com/*",
        "*://*.youtube.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ]
}
